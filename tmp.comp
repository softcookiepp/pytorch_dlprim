#if CONVGEMM != 0
    #if CONVGEMM == 3
    void add_img_value(__global float *ptr,uint matrix_row,uint matrix_col,float dV)
    #else
    float get_img_value(__global float const *ptr,uint matrix_row,uint matrix_col)
    #endif
    {
#if KERN_W == 1 && KERN_H == 1 && STRIDE_H == 1 && STRIDE_W == 1 && DILATE_H == 1 && DILATE_W == 1 \
        && PAD_H == 0 && PAD_W == 0 && GROUPS == 1 && IMG_COLS == SRC_COLS && IMG_ROWS == SRC_ROWS 
        uint channel = matrix_col;
        uint b  = matrix_row / (IMG_COLS * IMG_ROWS);
        uint rc = matrix_row % (IMG_COLS * IMG_ROWS);

        uint address = (b * CHANNELS_IN + channel) * (SRC_ROWS * SRC_COLS) + rc;
        #if CONVGEMM != 3
            return ptr[address];
        #else
            #if REDUCE_K > 1
                atomic_addf(ptr+address,dV);
            #else
                ptr[address] += dV;
            #endif
        #endif
#else
        uint channel = matrix_col / (KERN_H * KERN_W);
        uint k_index = matrix_col % (KERN_H * KERN_W);
        
        uint dy = k_index / KERN_W;
        uint dx = k_index % KERN_W;
        
        uint b  = matrix_row / (IMG_COLS * IMG_ROWS);
        uint rc = matrix_row % (IMG_COLS * IMG_ROWS);

        uint r  = rc / IMG_COLS;
        uint c  = rc % IMG_COLS;

        uint y_pos = -PAD_H + r * STRIDE_H;
        uint x_pos = -PAD_W + c * STRIDE_W;

        uint y = y_pos + dy * DILATE_H;
        uint x = x_pos + dx * DILATE_W;

        uint address = ((b *  (CHANNELS_IN*GROUPS) + channel) * SRC_ROWS + y) * SRC_COLS + x;

        #if CONVGEMM != 3
            #if PAD_W > 0 || PAD_H > 0
                if(x >= 0 && y >= 0 && x < SRC_COLS && y < SRC_ROWS) {
                    return ptr[address];
                }
                return 0;
            #else
                return ptr[address];
            #endif  
        #else
            #if PAD_W > 0 || PAD_H > 0
                if(x >= 0 && y >= 0 && x < SRC_COLS && y < SRC_ROWS) 
                    atomic_addf(ptr+address,dV);
            #else
                atomic_addf(ptr+address,dV);
            #endif
        #endif
#endif  
    }
#endif



